{
  "description": "Sample OBD-II CAN frames for testing",
  "frames": {
    "rpm_3000": {
      "description": "Engine RPM response - 3000 RPM",
      "can_id": "0x7E8",
      "data": "04 41 0C 2E E0 00 00 00",
      "decoded": {
        "mode": "0x41",
        "pid": "0x0C",
        "value_hex": "0x2EE0",
        "formula": "((A * 256) + B) / 4 = ((0x2E * 256) + 0xE0) / 4 = 12000 / 4",
        "value": 3000,
        "unit": "rpm"
      }
    },
    "rpm_idle": {
      "description": "Engine RPM response - idle (~800 RPM)",
      "can_id": "0x7E8",
      "data": "04 41 0C 0C 80 00 00 00",
      "decoded": {
        "value": 800,
        "unit": "rpm"
      }
    },
    "rpm_redline": {
      "description": "Engine RPM response - redline (7000 RPM)",
      "can_id": "0x7E8",
      "data": "04 41 0C 6D 60 00 00 00",
      "decoded": {
        "value": 7000,
        "unit": "rpm"
      }
    },
    "speed_100kmh": {
      "description": "Vehicle speed - 100 km/h",
      "can_id": "0x7E8",
      "data": "03 41 0D 64 00 00 00 00",
      "decoded": {
        "value": 100,
        "unit": "km/h"
      }
    },
    "coolant_temp_90c": {
      "description": "Coolant temperature - 90°C",
      "can_id": "0x7E8",
      "data": "03 41 05 82 00 00 00 00",
      "decoded": {
        "formula": "A - 40 = 130 - 40",
        "value": 90,
        "unit": "°C"
      }
    },
    "throttle_50pct": {
      "description": "Throttle position - 50%",
      "can_id": "0x7E8",
      "data": "03 41 11 80 00 00 00 00",
      "decoded": {
        "formula": "(A * 100) / 255 = (128 * 100) / 255",
        "value": 50.2,
        "unit": "%"
      }
    },
    "supported_pids": {
      "description": "Supported PIDs [01-20] response",
      "can_id": "0x7E8",
      "data": "06 41 00 BE 1F B8 10 00",
      "decoded": {
        "bitmask": "0xBE1FB810",
        "supported_pids": [1, 3, 4, 5, 6, 7, 12, 13, 14, 15, 16, 17, 19, 20, 21, 22, 28]
      }
    },
    "negative_response": {
      "description": "Negative response - service not supported",
      "can_id": "0x7E8",
      "data": "03 7F 01 11 00 00 00 00",
      "decoded": {
        "error": "Service not supported",
        "service": "0x01",
        "error_code": "0x11"
      }
    },
    "multiframe_first": {
      "description": "First frame of multi-frame response (20 bytes total)",
      "can_id": "0x7E8",
      "data": "10 14 41 00 BE 1F B8 10"
    },
    "multiframe_consecutive": {
      "description": "Consecutive frame (sequence 1)",
      "can_id": "0x7E8",
      "data": "21 C0 00 00 00 00 00 00"
    }
  },
  "requests": {
    "rpm": {
      "description": "Request engine RPM (Mode 01, PID 0C)",
      "can_id": "0x7DF",
      "data": "02 01 0C 00 00 00 00 00"
    },
    "speed": {
      "description": "Request vehicle speed (Mode 01, PID 0D)",
      "can_id": "0x7DF",
      "data": "02 01 0D 00 00 00 00 00"
    },
    "supported_pids": {
      "description": "Request supported PIDs (Mode 01, PID 00)",
      "can_id": "0x7DF",
      "data": "02 01 00 00 00 00 00 00"
    }
  }
}
